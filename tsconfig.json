{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "paths": {
      "@schemasset/cli": ["./packages/cli/src/index.ts"],
      "@schemasset/core": ["./packages/core/src/index.ts"],
      "@schemasset/nuxt": ["./packages/nuxt/src/index.ts"],
      "@schemasset/schema": ["./packages/schema/src/index.ts"],
      "@schemasset/utils": ["./packages/utils/src/index.ts"]
    },
    "types": ["node"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": true,
    "noEmit": true,
    "skipDefaultLibCheck": true,
    "skipLibCheck": true
  },
  "include": [
    "vite.config.ts",
    "packages/*/build.config.ts",
    "packages/*/src",
    "packages/*/vite.config.ts",
    "packages/schema/scripts",
    "test"
  ]
}
